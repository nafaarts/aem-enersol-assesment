{
  "name": "aem-dashboard",
  "version": "0.0.0",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently --kill-others \"ng serve\" \"wait-on http://localhost:4200 && npm run electron:build && env -u ELECTRON_RUN_AS_NODE ELECTRON_START_URL=http://localhost:4200 electron .\"",
    "electron:prod": "ng build --configuration production --base-href ./ && npm run electron:build && env -u ELECTRON_RUN_AS_NODE electron ."
  },
  "private": true,
  "dependencies": {
    "@amcharts/amcharts5": "^5.12.0",
    "@angular/animations": "^14.2.0",
    "@angular/common": "^14.2.0",
    "@angular/compiler": "^14.2.0",
    "@angular/core": "^14.2.0",
    "@angular/forms": "^14.2.0",
    "@angular/platform-browser": "^14.2.0",
    "@angular/platform-browser-dynamic": "^14.2.0",
    "@angular/router": "^14.2.0",
    "foundation-sites": "^6.9.0",
    "pouchdb": "^9.0.0",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^14.2.13",
    "@angular/cli": "~14.2.13",
    "@angular/compiler-cli": "^14.2.0",
    "@types/jasmine": "~4.0.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.18.126",
    "@types/pouchdb": "^6.4.2",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "jasmine-core": "~4.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~4.7.2",
    "wait-on": "^9.0.5"
  }
}
