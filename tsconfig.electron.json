{
    "compilerOptions": {
        "target": "ES2017",
        "module": "node16",
        "moduleResolution": "NodeNext",
        "outDir": "./dist-electron",
        "rootDir": "./electron",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "electron/**/*.ts",
        "electron/**/*.mts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "dist-electron"
    ]
}